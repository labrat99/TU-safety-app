# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VERTEX_PROJECT_ID: The Google Cloud Project ID for Vertex AI.
# Define this to utilize Vertex AI billing to consume Google Cloud promotional credits.
VERTEX_PROJECT_ID=

# VERTEX_LOCATION: The region/location for Vertex AI API resources (e.g., us-central1).
VERTEX_LOCATION=

# GOOGLE_APPLICATION_CREDENTIALS: Path to raw Google Cloud service account JSON file for ADC authentication.
GOOGLE_APPLICATION_CREDENTIALS=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
